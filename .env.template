# ============================================
# AI员工：竞品与行业动态情报系统 — 环境变量
# 复制此文件为 .env 并填入实际值
# ============================================

# Anthropic API Key (必须)
ANTHROPIC_API_KEY=sk-f693a19b5d7b48f08e4eda4942b6bac9

# LLM 配置 (可选，默认使用 claude-sonnet-4-6)
# AI_MODEL=claude-sonnet-4-6
# AI_MAX_TOKENS=4096
# AI_TEMPERATURE=0.3

# 邮件 SMTP 配置 (必须，用于发送报告)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notify@example.com
SMTP_PASSWORD=your_password_here
SMTP_FROM=AI情报员工 <notify@example.com>

# 企业微信机器人 Webhook (可选)
WECHAT_BOT_WEBHOOK=

# 代理配置 (可选)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080

# 数据目录 (可选，默认 ./data/)
# DATA_DIR=./data

# 日志级别 (可选，默认 INFO)
# LOG_LEVEL=INFO
