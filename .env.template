# ============================================
# AI员工：竞品与行业动态情报系统 — 环境变量
# 复制此文件为 .env 并填入实际值
# ============================================

# LLM Provider: anthropic / deepseek / openai_compatible
AI_PROVIDER=anthropic

# Anthropic API Key（AI_PROVIDER=anthropic 时使用，通常以 sk-ant- 开头）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# DeepSeek API Key（AI_PROVIDER=deepseek 时使用）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# LLM 配置（可选；填写后会覆盖 config/monitor_config.json 中的 ai_settings）
AI_MODEL=claude-sonnet-4-6
# AI_API_BASE=https://api.deepseek.com
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.3
AI_MAX_CONCURRENT=5

# 邮件 SMTP 配置 (必须，用于发送报告)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notify@example.com
SMTP_PASSWORD=your_password_here
SMTP_FROM=AI情报员工 <notify@example.com>

# 企业微信机器人 Webhook (可选)
WECHAT_BOT_WEBHOOK=

# 代理配置 (可选)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080

# 数据目录 (可选，默认 ./data/)
# DATA_DIR=./data

# 日志级别 (可选，默认 INFO)
# LOG_LEVEL=INFO
